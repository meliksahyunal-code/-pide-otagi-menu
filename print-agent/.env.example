# Print Agent Ortam Ayarları
# Bu dosyayı kopyalayıp .env olarak kaydedin

# Backend API URL (Render.com'daki backend adresiniz)
API_URL=https://pide-otagi-backend.onrender.com

# Yazıcı bağlantı tipi: "usb" veya "tcp"
PRINTER_TYPE=usb

# TCP modu için (Ethernet kablo kullanıyorsanız):
PRINTER_IP=192.168.1.200
PRINTER_PORT=9100

# USB modu için Windows'ta genellikle otomatik bulunur
# Eğer bulamazsa aşağıdaki satırı açın:
# PRINTER_USB_PATH=\\\\?\\usb#vid_...

# Kaç saniyede bir yeni sipariş kontrol edilsin?
POLL_INTERVAL=3000

# Günlük sipariş numarası sıfırlama saati (24h format)
RESET_HOUR=6
